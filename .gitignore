# =============================================================================
# HOME ASSISTANT GIT IGNORE
# =============================================================================
# Rename this file to .gitignore in your config directory

# =============================================================================
# SECRETS - CRITICAL: Never commit these!
# =============================================================================
secrets.yaml
google_service_account.json
.env
*_secrets.py
*.pem
*.key
*.crt

# =============================================================================
# SSL CERTIFICATES
# =============================================================================
/ssl/

# =============================================================================
# DATABASES - Large files, constantly changing
# =============================================================================
*.db
*.db-shm
*.db-wal
home-assistant_v2.db*
home-assistant.log*

# =============================================================================
# RUNTIME/CACHE FILES
# =============================================================================
.storage/
.cloud/
.HA_VERSION
__pycache__/
*.pyc
*.pyo
.uuid

# =============================================================================
# BACKUP FILES
# =============================================================================
*.bak
*.backup
backups/

# =============================================================================
# EDITOR/IDE FILES
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# GENERATED/TEMPORARY FILES
# =============================================================================
tts/
www/community/
www/icloud3/
deps/
OZW_Log.txt
ozw*.xml
.ha_run.lock
icloud3.log*
ip_bans.yaml
claude_snapshot.md
.claude/

# =============================================================================
# CUSTOM COMPONENTS (optional - uncomment if you want to track them)
# =============================================================================
custom_components

# =============================================================================
# FILES THAT CHANGE FREQUENTLY (optional - consider excluding)
# =============================================================================
# Uncomment these if you don't want to track UI-edited files:
# automations.yaml
# scripts.yaml
# scenes.yaml

# =============================================================================
# ZIGBEE/ZHA DATABASE
# =============================================================================
zigbee.db*
zigbee2mqtt/log
zigbee2mqtt/coordinator_backup.json
zigbee2mqtt/database.db
zigbee2mqtt/state.json
zigbee2mqtt/configuration_backup_*.yaml
zigbee2mqtt/migration-*.log
zigbee2mqtt/secrets.yaml

# =============================================================================
# NODE-RED (if using)
# =============================================================================
node-red/

# =============================================================================
# SPECIFIC TO YOUR SETUP
# =============================================================================
# Add any custom exclusions below:
.mcp.json
.ssh
www/screenshots/

# Solcast cache files (keep sites.json)
solcast_solar/solcast.json
solcast_solar/solcast-actuals.json
solcast_solar/solcast-undampened.json
solcast_solar/solcast-usage.json
watchman_report.txt

# Notebook generated HTML output (contain embedded Mapbox tokens)
notebooks/**/*.html

# Notebooks (embedded git repos)
notebooks/bokeh-examples/
notebooks/home-assistant/
.ipynb_checkpoints/

# Trash
.Trash-0/
.cache/
